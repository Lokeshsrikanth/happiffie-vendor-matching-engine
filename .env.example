# -----------------------------------------------------------------------------
# Happiffie Matching Engine - Environment Configurations Template
# Copy this file to '.env' (or set these inside Render/Railway/Vercel settings)
# -----------------------------------------------------------------------------

# --- DATABASE CONFIGS (Backend) ---
# Postgres connection string. The database MUST have the pgvector extension enabled.
# For local Docker Compose, use: postgresql://postgres:postgres@localhost:5435/happiffie?schema=public
DATABASE_URL="postgresql://username:password@hostname:5432/dbname?schema=public"

# --- SERVER PORT & CORS (Backend) ---
# Port on which the Express backend will run (default is 4000)
PORT=4000
# Allowed CORS origins, separated by commas. Use '*' to allow all in development.
CORS_ORIGIN="*"

# --- AI & EMBEDDINGS PROVIDER KEYS (Backend) ---
# Anthropic API Key (Claude) for plain-English requirement parsing and rationale generation.
# If omitted or invalid, the backend gracefully falls back to rule-based parser & rationales.
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# --- FRONTEND CONFIGS (Vercel / Frontend) ---
# Deployed backend API base URL (e.g. https://happiffie-api.up.railway.app).
# Leave blank or omit in local development when using Vite's development proxy.
VITE_API_BASE_URL="http://localhost:4000"
